Algoritmo "ex13"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 26/02/2026

// Seçăo de Declaraçőes das variáveis 
Var
   valor, desconto, preço: real

Inicio
   escreva("Digite o valor da sua compra: ")
   leia(valor)

   se (valor > 100) entao
      desconto <- valor * 10 / 100
      preço <- valor - desconto
      escreva("Desconto de 10% aplicado")
      escreva("Valor final: ", preço)
   senao
      escreva("Sem desconto.")
      escreva("Valor final: ", valor)
   fimse
Fimalgoritmo


// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 




