Algoritmo "ex6"
// 
//  
// Descrição   : Aqui você descreve o que o programa faz! (função)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 13/02/2026

Var
resto, divisao: real

Inicio
Escreval("Digite um numero: ")
leia(resto)
divisao<-resto mod 2
Fimalgoritmo

